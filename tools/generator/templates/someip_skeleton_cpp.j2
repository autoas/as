{% set _ = args.append(arg) %}
{% endfor %}
{% endif %}
{% set res_payload_size = GetTypePayloadSize(ReturnType, allStructs) %}
static ara::core::Future<{{ ReturnType }}> s_future{{ method['name'] }};
static bool s_{{ method['name'] }}InRequest = false;
{% if method.get('tp', false) %}
static uint8_t s_{{ method['name'] }}RequestPayload[{{ args_payload_size }} + {{ GetE2EOverhead(method, 'RX') }}];
{% endif %}
static uint8_t s_{{ method['name'] }}ResponsePayload[{{ res_payload_size }} + 20 + {{ GetE2EOverhead(method, 'TX') }}];

Std_ReturnType SomeIp_{{ service_name }}_{{ method['name'] }}_OnRequest(uint32_t requestId, SomeIp_MessageType *req, SomeIp_MessageType *res) {
  Std_ReturnType ret = E_OK;
  int32_t serializedSize;
{% for arg in args %}
  static {{ arg['type'] }} {{ arg['name'] }};
{% endfor %}
  ASLOG({{ service_name | toMacro }}, ("{{ method['name'] }} OnRequest %X: len=%d, data=[%02X %02X %02X %02X ...]\n", requestId,
                        req->length, req->data[0], req->data[1], req->data[2], req->data[3]));
  
{% if method.get('useE2E', false) and 'E2E-RX' in method %}
  /* Check E2E protection */
  ret = E2E_P{{ method['E2E-RX']['profile'][1:] }}Check(E2E_CHECK_P{{ method['E2E-RX']['profile'][1:] }}_{{ service_name | toMacro }}_{{ method['name'] | toMacro }}_RX, req->data, req->length);
  if (E_OK == ret || E2E_E_OK_SOME_LOST == ret) {
    ret = E_OK;
{% endif %}
    if (nullptr != s_h{{ service_name }}) {
      int32_t offset = {{ GetE2EOffset(method, 'RX') }};
{% for arg in args %}
      if ((offset >= 0) && (offset < (int32_t)req->length)) {
        serializedSize = {{ arg | SomeIpXfDecode(allStructs, '&req->data[offset]', 'req->length - offset', arg['name']) }};
        if (serializedSize > 0) {
          offset += serializedSize;
        } else {
          offset = -ENOSPC;
        }
      }
{% endfor %}
      if (true == s_{{ method['name'] }}InRequest) {
        ASLOG({{ service_name | toMacro }}_E, ("{{ method['name'] }} is busy in request!\n"));
        ret = E_NOT_OK;
      } else if (offset >= 0) {
        s_{{ method['name'] }}InRequest = true;
        s_future{{ method['name'] }} = s_h{{ service_name }}->{{ method['name'] }}({% for arg in args %}{{ arg['name'] }}{% if not loop.last %},{% endif %}{% endfor %});
        if (true == s_future{{ method['name'] }}.is_ready()) {
{% if ReturnType != 'void' %}
          ara::core::Result<{{ ReturnType }}> result = s_future{{ method['name'] }}.GetResult();
          if (result.HasValue()) {
            int32_t offset = 20;
            offset += {{ GetE2EOffset(method, 'TX') }};
            res->data = &s_{{ method['name'] }}ResponsePayload[20];
            serializedSize = {{ ReturnType | SomeIpXfEncode(allStructs, '&s_'+method['name']+'ResponsePayload[offset]', 'sizeof(s_'+method['name']+'ResponsePayload)-offset', 'result.Value()') }};
            if (serializedSize > 0) {
{% if method.get('useE2E', false) and 'E2E-TX' in method %}
              /* Apply E2E protection */
              ret = E2E_P{{ method['E2E-TX']['profile'][1:] }}Protect(E2E_PROTECT_P{{ method['E2E-TX']['profile'][1:] }}_{{ service_name | toMacro }}_{{ method['name'] | toMacro }}_TX, res->data, serializedSize + {{ GetE2EOverhead(method, 'TX') }});
              if (E_OK == ret) {
{% endif %}
                res->length = serializedSize + {{ GetE2EOverhead(method, 'TX') }};
                if (serializedSize <= SOMEIP_SF_MAX) {
                  s_{{ method['name'] }}InRequest = false;
                }
{% if method.get('useE2E', false) and 'E2E-TX' in method %}
              }
{% endif %}
            } else {
              ASLOG({{ service_name | toMacro }}_E, ("{{ method['name'] }} encode response failed!\n"));
              ret = E_NOT_OK;
              s_{{ method['name'] }}InRequest = false;
            }
          } else {
            ASLOG({{ service_name | toMacro }}_E, ("{{ method['name'] }} execution failed!\n"));
            ret = E_NOT_OK;
            s_{{ method['name'] }}InRequest = false;
          }
{% else %}
          // For void return type, no HasValue() check
          res->data = &s_{{ method['name'] }}ResponsePayload[20];
          res->length = 0;
          s_{{ method['name'] }}InRequest = false;
{% endif %}
        } else {
          ret = SOMEIP_E_PENDING;
        }
      } else {
        ASLOG({{ service_name | toMacro }}_E, ("{{ method['name'] }} decode args failed!\n"));
        ret = E_NOT_OK;
      }
    }
{% if method.get('useE2E', false) and 'E2E-RX' in method %}
  } else {
    ASLOG({{ service_name | toMacro }}_E, ("E2E check failed for {{ method['name'] }}, ercd=0x%x\n", ret));
  }
{% endif %}
  return ret;
}

