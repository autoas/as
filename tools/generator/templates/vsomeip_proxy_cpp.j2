    m_app->init();
    // m_app->set_client({{ service['clientId'] }});
  }
  
  ~{{ service_name }}Manager() {
    if (m_app) {
      m_app->stop();
    }
    if (m_thread.joinable()) {
      m_thread.join();
    }
  }
  
  void ThreadMain() {
    m_app->start();
  }
  
  std::shared_ptr<vsomeip::application> m_app;
  bool m_isAvailable = false;
  bool m_appStarted = false;
  std::thread m_thread;
