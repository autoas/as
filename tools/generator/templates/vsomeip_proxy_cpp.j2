      app->request_service({{ service['service'] }}, {{ service['instance'] }});
      m_thread = std::thread(&{{ service_name }}Manager::ThreadMain, this);
      m_appStarted = true;
    }

    if (true == m_isAvailable) {
      ServiceHandleContainer<{{ service_name }}Proxy::HandleType> shc;
      shc.push_back({{ service_name }}Proxy::HandleType());
      rslt = Result<ServiceHandleContainer<{{ service_name }}Proxy::HandleType>>(shc);
    }
    return rslt;
  }

  void OnAvailability(vsomeip::service_t service, vsomeip::instance_t instance, bool isAvailable) {
    m_isAvailable = isAvailable;
  }

