    Result<ServiceHandleContainer<{{ service_name }}Proxy::HandleType>> rslt({});
    auto app = GetApplication();
    if ((false == m_isAvailable) && (false == m_appStarted)) {
      app->register_availability_handler({{ service['service'] }}, {{ service['instance'] }},
