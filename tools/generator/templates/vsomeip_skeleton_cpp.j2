    {% if 'args' in method %}
    {% set method_args = GetArgs(cfg, method['args']) %}
    {% for arg in method_args %}
    static {{ arg['type'] }} {{ arg['name'] }};
    {% endfor %}
    
    if (msg->get_payload()) {
      int32_t offset = 0;
      {% for arg in method_args %}
      int32_t argSize = {{ arg | SomeIpXfDecode(allStructs, 'msg->get_payload()->get_data() + offset', 'msg->get_payload()->get_length() - offset', arg['name']) }};
      if (argSize > 0) {
        offset += argSize;
      } else {
        res->set_return_code((vsomeip::return_code_e)E_NOT_OK);
        m_app->send(res);
        return;
      }
      {% endfor %}
    }
    {% endif %}
    
    // Call the method
    auto future = {{ method['name'] }}({% for arg in method_args %}{{ arg['name'] }}{% if not loop.last %},{% endif %}{% endfor %});
    
    if (future.is_ready()) {
      auto result = future.GetResult();
      if (result.HasValue()) {
        {% if method.get('return', 'void') != 'void' %}
        // Encode response
        uint8_t response[20 + {{ method.get('return', 'void') | getTypePayloadSize(allStructs) }}];
        int32_t serializedSize = {{ method.get('return', 'void') | SomeIpXfEncode(allStructs, '&response[20]', 'sizeof(response) - 20', 'result.Value()') }};
        if (serializedSize > 0) {
          auto payload = vsomeip::runtime::get()->create_payload();
          payload->set_data(&response[20], serializedSize);
          res->set_payload(payload);
          res->set_return_code((vsomeip::return_code_e)E_OK);
        } else {
          res->set_return_code((vsomeip::return_code_e)E_NOT_OK);
        }
        {% else %}
        res->set_return_code((vsomeip::return_code_e)E_OK);
        {% endif %}
      } else {
        res->set_return_code((vsomeip::return_code_e)E_NOT_OK);
      }
      m_app->send(res);
    } else {
