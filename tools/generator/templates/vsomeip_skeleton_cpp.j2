void {{ field['name'] }}::OnGetRequest(const std::shared_ptr<vsomeip::message> &msg) {
  if (!msg) return;

  auto res = vsomeip::runtime::get()->create_response(msg);
  bool bValid = false;
  int32_t serializedSize;
  if (nullptr != m_getHandler) {
    // Create local future variable
    auto future = m_getHandler();
    // Wait for the future to be ready
    ara::core::Result<FieldType> result = future.GetResult();
    if (result.HasValue()) {
        m_fieldGet = result.Value();
        bValid = true;
    }
  } else if (true == m_bValid) {
    bValid = true;
  }

  if (true == bValid) {
    serializedSize = {{ field | SomeIpXfEncode(allStructs, 'm_responseGet', 'sizeof(m_responseGet)', 'm_fieldGet') }};
    if (serializedSize > 0) {
      auto rtm = vsomeip::runtime::get();
      auto payload = rtm->create_payload();
      payload->set_data(m_responseGet, serializedSize);
      res->set_payload(payload);
      res->set_message_type(vsomeip::message_type_e::MT_RESPONSE);
      res->set_return_code((vsomeip::return_code_e)E_OK);
      m_app->send(res);
    }
  } else {
    res->set_return_code((vsomeip::return_code_e)E_NOT_OK);
    m_app->send(res);
  }
}

