  int32_t serializedSize = 
    {{ event | SomeIpXfEncode(allStructs, '&m_payload[20]', 'sizeof(m_payload) - 20', 'data') }};
  if (serializedSize > 0) {
    auto rtm = vsomeip::runtime::get();
    auto request = rtm->create_request();
    request->set_service({{ service['service'] }});
    request->set_instance({{ service['instance'] }});
    request->set_method({{ event['eventId'] }});
    request->set_message_type(vsomeip::message_type_e::MT_NOTIFICATION);
    
    auto payload = rtm->create_payload();
    payload->set_data(&m_payload[20], serializedSize);
    request->set_payload(payload);
    
    m_app->notify({{ service['service'] }}, {{ service['instance'] }}, {{ event['eventId'] }}, payload);
