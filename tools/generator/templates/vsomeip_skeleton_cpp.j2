{{ service_name }}Skeleton::{{ service_name }}Skeleton(const InstanceIdentifier &instanceId,
                                           MethodCallProcessingMode mode) {
  if (nullptr == s_h{{ service_name }}) {
    s_h{{ service_name }} = this;
  } else {
    throw std::runtime_error("{{ service_name }} already created");
  }

  m_mode = mode;
  m_serviceId = {{ service['service'] }};
  m_instanceId = {{ service['instance'] }};
  m_serviceOffered = false;
  
  auto rtm = vsomeip::runtime::get();
  m_app = rtm->create_application("{{ service_name }}Skeleton");
  m_app->init();
  m_app->register_message_handler(m_serviceId, m_instanceId, vsomeip::ANY_METHOD, 
                                 std::bind(&{{ service_name }}Skeleton::OnMessage, this, std::placeholders::_1));
}

void {{ service_name }}Skeleton::ThreadMain() {
  m_app->start();
}

{{ service_name }}Skeleton::~{{ service_name }}Skeleton() {
  if (this == s_h{{ service_name }}) {
    s_h{{ service_name }} = nullptr;
  }
  
  if (m_app) {
    m_app->stop_offer_service(m_serviceId, m_instanceId);
    m_app->stop();
    if (m_thread.joinable()) {
      m_thread.join();
    }
  }
}

